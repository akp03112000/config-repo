server:
  port: 8080

spring:
  application:
    name: api-gateway

  cloud:
    gateway:
      routes:

        # 🔐 AUTH SERVICE
        - id: auth-service
          uri: lb://auth-service
          predicates:
            - Path=/auth/**

        # 🛍️ CATALOG SERVICE
        - id: catalog-service
          uri: lb://catalog-service
          predicates:
            - Path=/products/**

        # 📦 ORDER SERVICE
        - id: order-service
          uri: lb://order-service
          predicates:
            - Path=/orders/**

        # 🧑‍💼 ADMIN SERVICE
        - id: admin-service
          uri: lb://admin-service
          predicates:
            - Path=/admin/**

        # 🔥 SWAGGER DOC ROUTES

        - id: auth-docs
          uri: lb://auth-service
          predicates:
            - Path=/auth/v3/api-docs

        - id: catalog-docs
          uri: lb://catalog-service
          predicates:
            - Path=/catalog/v3/api-docs

        - id: order-docs
          uri: lb://order-service
          predicates:
            - Path=/order/v3/api-docs

        - id: admin-docs
          uri: lb://admin-service
          predicates:
            - Path=/admin/v3/api-docs

# 🔥 CENTRAL SWAGGER UI CONFIG

springdoc:
  swagger-ui:
    urls:
      - name: Auth Service
        url: /auth/v3/api-docs
      - name: Catalog Service
        url: /catalog/v3/api-docs
      - name: Order Service
        url: /order/v3/api-docs
      - name: Admin Service
        url: /admin/v3/api-docs
